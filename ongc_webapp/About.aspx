<%@ Page Title="About ONGC Foundation" Language="C#" MasterPageFile="~/Site.Master" AutoEventWireup="true" CodeBehind="About.aspx.cs" Inherits="ongc_webapp.About" %>

<asp:Content ID="BodyContent" ContentPlaceHolderID="MainContent" runat="server">
    <div class="container mt-5">
        <div class="row align-items-center">
            <div class="col-md-7 pe-md-5">
                <h6 class="text-uppercase fw-bold style-track" style="color: #800000; letter-spacing: 1px;">Corporate Social Responsibility</h6>
                <h1 class="fw-extrabold mb-4" style="color: #2D3748; font-weight: 800;">About ONGC Foundation</h1>
                <p class="text-secondary lead mb-4" style="font-size: 1.1rem; line-height: 1.7;">
                    With the vision of impacting and socially transforming the lives of the underprivileged, ONGC created the ONGC Foundation Trust to undertake, augment, and facilitate large-scale initiatives relating to corporate social responsibility.
                </p>
                <p class="text-secondary mb-4" style="line-height: 1.6;">
                    We envision a sustainable world where the deprived sections of our society are transformed and empowered to lead a quality life with dignity. Through strategic investments in education, healthcare, and infrastructure engineering, we aim to establish a framework for national development priorities.
                </p>
            </div>
            
            <div class="col-md-5 mt-4 mt-md-0">
                <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 12px;">
                    <img src="ongc_refinery.jpg" alt="ONGC Operational Infrastructure" class="img-fluid" style="image-rendering: -webkit-optimize-contrast;" />
                </div>
            </div>
        </div>
    </div>
</asp:Content>